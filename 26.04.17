#구구단 파이썬 버전
for dan in range(2,10):  #dan이라는 상자에 2부터 9까지 (10직전까지) 숫자를 하나씩 넣으면서 아래 내용을 반복해! 라는 뜻을 가지고 있음
  print(f"---{dan}단 ---")  # 지금 몇단을 계산하고 있는지 제목을 붙여줘
  #각 단에서 1부터 9까지 곱할 거야 
    for i in range(1,10):  # 이건 반복문 안의 반복문, 2단이 선택되면 그 안에서 다시 1부터 9까지 곱하는 과정을 반복
      print(f"{dan} x{i} = {dan *i}")  #dan * i : 실제로 숫자를 곱해서 결과를 보여줘


#구구단 자바 버전
puvlic class Main {  # 자바에서 시작 타이틀 (class 이름 뒤에 파일이름이랑 같아야함
  public static void main(String[] args) {     # 시작할때 꼭 필요함
    //단을 2부터 9까지 반복
      for (int dan = 2; dan <= 9; dan++) { # int dan = 2; 정수(int) 형태의 dan 이라는 상자를 만들고 2를 넣어줘 라는 종류
                                            # 언제까지 반복할까 dan <=9;   dan이 0랑 같거나 작을 때까지 계속 이라는 조건
                                            # dan++ 한바퀴 돌 때마다 숫자를 1씩 키워줘 라는 뜻
      // 1부터 9까지 곱하기 반복
        for (int i = 1; i <= 9; i++) {  # 9번을 반복 해라
          System.out.printIn(dan + "x" + i + "=" + (dan *i))'
        }
      }
    }
  }


  # 구구단 C++ 버전
  #include <iostream>     # 화면에 글자를 보여주는 기능
  using namespace std;

  int main() {
    // 2단부터 9단까지
      for(int dan = 2; dan <= 9; ++dan) {
        cout << "--- " << dan << "단 ---" << endl:    # cout << ... : 파있너의 print 처럼 화면에 글자를 내보내는 (out) 통로 
                                                      #   <<  화살표 방향 대로 데이터가 흘러나가서 화면에 보임
        //1부터 9까지 곱하기
        for (int i = 1; i <=9; ++i) {
        cout << dan <, "x" << i << "=" << dan * i << endl;   #endl: 줄 바꿈의 줄임말 다음 줄로 넘어가라는 뜻
        }
      }
      return 0:
  }
