package javapro; // 이 클래스가 속한 패키지(폴더)를 정의하는 곳

import java.util.Scanner; // 키보드 입력을 받기 위해 자바 표준 라이브러리에서 Scanner 클래스를 불러오는곳

public class WonToDollar { // 클래스 선언부, 파일명과 클래스명이 동일해야 함
    
    // 프로그램이 실행될 때 가장 먼저 호출되는 메인 메소드 시작점
    public static void main(String[] args) { 
        
        // Scanner 객체를 생성하여 키보드 입력(System.in)을 받는 곳
        Scanner scanner = new Scanner(System.in);
        
        // 사용자에게 입력할 내용을 안내하는 문구를 화면에 출력 (줄바꿈 없음)
        System.out.print("원화를 입력하세요(단위 원) ");
        
        // 사용자가 입력한 정수 값을 읽어와서 'won'이라는 변수에 저장
        int won = scanner.nextInt();
        
        // 입력받은 원화를 1500으로 나누어 달러 값을 계산
        // 소수점 계산을 정확히 하기 위해 1500.0(실수)으로 나누어 결과를 double 타입에 저장합니다.
        double dollar = won / 1500.0;
        
        // 계산된 결과값들을 문자열과 합쳐서 화면에 한 줄로 출력
        System.out.println(won + "원은 $" + dollar + "입니다.");
        
        // 사용이 끝난 스캐너 객체를 닫아 시스템 끝내기
        scanner.close();
    }
}

