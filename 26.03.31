package javapro;

import java.util.Scanner;

public class SeasonCheck {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);

        System.out.print("달을 입력하세요(1~12) ");
        int month = scanner.nextInt();

        // 계절은 하나만 해당되므로, 조건 하나가 맞으면 나머지 검사 
        
        // 3 '이상'이고 5 '이하'인 범위를 지정할 때 씁니다.
        if (month >= 3 && month <= 5) {
            System.out.println("봄");
        } 
        else if (month >= 6 && month <= 8) {
            System.out.println("여름");
        } 
        else if (month >= 9 && month <= 11) {
            System.out.println("가을");
        } 
        // [이유: ||(OR) 연산자 사용] 12월, 1월, 2월은 숫자가 떨어져 있으므로 "이것 중 하나라도 맞으면"이라는 뜻으로 씁니다.
        else if (month == 12 || month == 1 || month == 2) {
            System.out.println("겨울");
        } 
        // [이유: 예외 처리] 사용자가 1~12 이외의 숫자(예: 13, -1)를 넣었을 때 에러를 방지하기 위함입니다.
        else {
            System.out.println("잘못 입력하였습니다.");
        }

        scanner.close();
    }
}
--------------------------------------------------------------------------------------
for문 예제문

package javapro;

public class ForSample {
	public static void main(String[] args) {
		int sum=0;
		
		for(int i =1; i<=10; i++) { //1~10까지 반목
			sum +=i;
			System.out.print(i); // 더하는 수 출력
			if(i<=9) //1~9가지는 '+' 출력
				System.out.print("+");
			else { //i가 10인 경우
				System.out.print("="); // '=' 출력하고
				System.out.print(sum); // 덧셈 결과 출력
			}
		}
	}
}


--------------------------------------------------------------------------------------
while 문 이용

package javapro;
import java.util.Scanner;
public class WhileSample {
	public static void main(String[] args) {
		int count=0; // count는 입력된 정수의 개수
		int sum=0; //sum은 합
		Scanner scanner = new Scanner(System.in);
		System.out.println("정수를 입력하고 마지막에 -1을 입력하세요");
		
		int n = scanner.nextInt(); // 정수 입력
		while(n != -1) { //-이 입력되면 while 문 벗어남
			sum += n;
			count++;
			n= scanner.nextInt(); //정수입력
		}
		if(count == 0) System.out.println("입력된 수가 없습니다.");
		else {
			System.out.print("정수의 개수는" + count + "개이며");
			System.out.println("평균은" + (double)sum/count + "입니다");
		}
		scanner.close();
	}
}

--------------------------------------------------------------------------------------
do while 문 예제

package javapro;
public class DoWhileSample {
	public static void main(String[] args) {
		char c ='a';
		
		do {
			System.out.print(c);
			c = (char)(c+1);
		}while(c<='z');
	}
}

--------------------------------------------------------------------------------------
중첩을 이용한 구구단  예제 문제
package javapro;
public class NestedLoop {
	public static void main(String[] args) {
		for(int i=1; i<10;i++) { // 1단에서 9단
			for(int j=1; j<10;j++) { // 각 단의 구구셈 출력
			System.out.print(i+"*"+j+"="+i*j); //구구셈 출력
			System.out.print('\t'); // 하나씩 탭으로 띄기
		}
		System.out.println(); //한 단이 끝나면 다음 줄로 커서 이동
		}
	}
}
--------------------------------------------------------------------------------------
continue문 양수 합 구하기

package javapro;
import java.util.Scanner;
public class ContiuneExample {
	public static void main(String[] args) {
		Scanner scanner = new Scanner(System.in);
		System.out.println("정수를 5개 입력하세요");
		int sum=0;
		for(int i=0; i<5;i++) {
			int n = scanner.nextInt();
			if(n<=0)
				continue;
			else 
				sum +=n;		
			}
			System.out.println("양수의 합은"+sum);
			scanner.close();
		}
	}

 --------------------------------------------------------------------------------------
break 문 이용하여 while 문 벗어나기

package javapro;
import java.util.Scanner;
public class BreakExample {
	public static void main(String[] args) {
		Scanner scanner = new Scanner(System.in);
		System.out.println("exit을 입력하면 종료합니다");
		while(true) {
			System.out.print(">>");
			String text=scanner.nextLine();
			if(text.equals("exit")) //"exit"이 입력되면 반복 종료
				break; //while 문을 벗어남
		}
		System.out.println("종료합니다...");
		scanner.close();
	}
}
