package javapro;

import java.util.Scanner;

public class CircleCheck {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);

        // 1. 원의 정보 입력
        System.out.print("원의 중심과 반지름을 입력하시오 >> ");
        double 원중심X = scanner.nextDouble();
        double 원중심Y = scanner.nextDouble();
        double 반지름 = scanner.nextDouble();

        // 2. 점의 좌표 입력
        System.out.print("점을 입력하시오 >> ");
        double 점X = scanner.nextDouble();
        double 점Y = scanner.nextDouble();

        // 3. 피타고라스 정리를 이용한 거리의 제곱 구하기
        // 루트를 씌우기 전 상태인 (x대비 거리^2 + y대비 거리^2)만 구합니다.
        double x거리 = 점X - 원중심X;
        double y거리 = 점Y - 원중심Y;
        double 거리제곱 = (x거리 * x거리) + (y거리 * y거리);

        // 4. 반지름도 제곱하여 비교 준비
        double 반지름제곱 = 반지름 * 반지름;

        // 5. 결과 출력 (거리제곱이 반지름제곱보다 작거나 같으면 원 안에 있음)
        if (반지름제곱 >= 거리제곱) {
            System.out.printf("점 (%.1f, %.1f)는 원 안에 있습니다.\n", 점X, 점Y);
        } else {
            System.out.printf("점 (%.1f, %.1f)는 원 안에 없습니다.\n", 점X, 점Y);
        }

        scanner.close();
    }
}
