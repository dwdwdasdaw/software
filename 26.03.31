package javapro; // 이 파일이 속한 패키지 경로

import java.util.Scanner; // 키보드 입력을 위해 스캐너 클래스

public class MoneyDivider2 { // 클래스 이름

    public static void main(String[] args) { // 프로그램 실행의 시작점
        // 스캐너 객체를 생성하여 키보드 입력 준비
        Scanner scanner = new Scanner(System.in);

        // 사용자에게 금액 입력을 요청하는 메시지를 출력합니다.
        System.out.print("금액을 입력하세요 ");
        // 입력받은 정수 값을 money 변수에 저장
        int money = scanner.nextInt();

        // [배열] 계산해야 할 화폐 단위들을 순서대로 저장
        int[] units = {50000, 10000, 5000, 1000, 500, 100, 50, 10, 1};
        // [배열] 각 화폐 단위에 매칭되는 한글 이름을 저장 (위 배열과 순서가 같아야 합니다.)
        String[] nameStrings = {"오만원권", "만원권", "오천원권", "천원권", "오백원", "백원", "오십원", "십원", "일원"};

        // [반복문] 화폐 단위 배열의 개수만큼 코드를 반복 실행 (0번부터 끝까지)
        for (int i = 0; i < units.length; i++) {
            // 현재 화폐 단위(units[i])로 나눈 '몫'을 구하여 개수를 계산합니다.
            int count = money / units[i];

            // 계산된 화폐 개수가 0보다 클 경우에만 화면에 출력
            if (count > 0) {
                // 삼항 연산자: 단위가 1000원 이상이면 "매", 아니면 "개"를 unitName에 저장
                String unitName = (units[i] >= 1000) ? "매" : "개";
                
                // 결과 출력 (예: 오만원권 1매)
                System.out.println(nameStrings[i] + " " + count + unitName);
            }
            
            // [중요] 해당 화폐 단위를 계산하고 남은 '나머지' 금액을 다시 money 변수에 업데이트
            // 그래야 다음 반복문에서 그다음 단위로 계산을 이어갈 수 있음
            money %= units[i];
        }

        // 사용이 끝난 스캐너를 닫기
        scanner.close();
    }
}

