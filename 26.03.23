<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>경로테스트</title>
</head>
<body>
    <img src="../images/notice.jpg" alt="notice"> <br> 
    <!-- 부분결로지정 -->
    <img src="data:image/jpeg;base64," alt="햄깅"> <br>  
<!-- 절대경로지정  -->
</body>
</html>

로그인창 만들기
<!DOCTYPE html>
<html lang="ko">
  <head>
		<meta charset="UTF-8">
		<title>로그인</title>
  </head>
  <body>
	<form>
    <fieldset>
      <!-- Do it! 텍스트 필드와 비밀번호 필드가 있는 로그인 폼 만들기 -->
<label>아 이 디: <input type="text" size="10" maxlength="10"></label><br/>
<label>비밀번호: <input type="password" size="15" maxlength="10"></label><br/>
<input type="image" src="./images/login.png"/>
<!-- <input type="submit" value="로그인"> -->
<input type="reset" value="cancel">
    </fieldset>
  </form>
  </body>
</html>

배송지 창 만들기
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>레드향 주문하기</title>
</head>
<body>
  <h1>레드향 주문하기</h1>
  <form action="">
    <fieldset>
      <legend>상품 선택</legend>
     
    </fieldset>

    <fieldset>
      <legend>배송 정보</legend>
      <!-- Do it! 배송 정보 입력하는 폼 만들기 -->
      <ul>
        <li>
          <label for="usre-name">이  름:</label>
          <input type="text" id="usre-name">
        </li>
        <li>
          <label for="addr">배송주소</label>
          <input type="url" id="addr">
        </li>
        <li>
          <label for="mail">이메일</label>
          <input type="email" id="mail">
        </li>
        <li>
          <label for="phone">연락처</label>
          <input type="tel" id="phone">
        </li>
      </ul>
    </fieldset> 
    <input type="submit" value="확인"/>
  </form>
</body>
</html>


배송 및 주문 요청서 만들기
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>레드향 주문하기</title>
</head>
<body>
  <h1>레드향 주문하기</h1>
  <form>
    <fieldset>
      <legend>상품 선택</legend>
      <!-- Do it! 라디오 버튼과 체크 박스를 사용한 폼 만들기 -->
 <p><b>주문할 상품을 선택해 주세요</b></p>
 <ul>
    <li><input type="checkbox" name="prod" id="p3"/> <label for="p3"> 선물용 3kg
      <input type="number" min="1" max="5" value="1"> (개)(최대5개)
    </label></li>
    <li><input type="checkbox" name="prod" id="p5"/><label for="p5"> 선물용 5kg</label></li>
    <li><input type="checkbox" name="prod" id="f3"/><label for="f3"> 가정용 3kg</label></li>
    <li><input type="checkbox" name="prod" id="f5"/><label for="f5"> 가정용 5kg</label></li>  
 </ul>
 <p><b>포장 선택</b></p>
 <ul>
  <li><label><input type="radio" name="gift" value="yes">선물 포장</label></li>
  <li><label><input type="radio" name="gift" value="nd">선물 포장 안 함</label></li>
 </ul>
    </fieldset>
    <fieldset>
      <legend>배송 정보</legend>
      <ul>
        <li>
          <label for="user-name">이름 </label>
          <input type="text" id="user-name">
        </li>
        <li>
          <label for="addr">배송 주소</label>
          <input type="text" id="addr">
        </li>
        <li>
          <label for="mail">메일 주소</label>
          <input type="email" id="mail">
        </li>        
        <li>
          <label for="phone">연락처</label>
          <input type="tel" id="phone">
        </li>
      </ul>  
      <input type="submit" value="확인"/>
    </fieldset>      
  </form>  
</body>
</html>

주문 페이지 고정 및 힌트 적용
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>레드향 주문하기</title>
  <link rel="stylesheet" href="css/order.css">
</head>
<body>
  <div id="container">
    <h1>레드향 주문하기</h1>
    <form>
      <fieldset>
        <legend>배송 정보</legend>
        <!-- Do it! 이름에 autofocus, 연락처에 placeholder 추가하기 -->
        <ul id="shipping">
          <li>            
            <label for="prod" >주문 상품 </label>
            <input type="text" readonly id="prod" value="상품용 3KG">
          </li>
          <li>            
            <label for="user-name" >이름 </label>
            <input type="text" id="user-name" required autofocus>
          </li>
          <li>
            <label for="addr">배송 주소</label> 
            <input type="text" id="addr" required>
          </li>
          <li>
            <label for="mail">이메일</label>
            <input type="email" id="mail">
          </li>        
          <li>
            <label for="phone">연락처</label>
            <input type="tel" id="phone" placeholder="하이폰 빼고 입력해주세요(01012345678)"required>
          </li>
          <li>
            <label for="d-day">배송 지정</label>
            <input type="date" id="d-day" required> <small>(주문일로부터 최소 3일 이후)</small>
          </li>        
        </ul>  
      </fieldset>
      <div id="buttons">
        <input type="submit" value="주문하기"> 
        <input type="reset" value="취소하기">
      </div>        
    </form>
  </div>
</body>
</html>

오늘의 과제물 제출
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>햄깅이 굿즈 신청서</title>
</head>
<body>

<h1>
<b><legend>굿즈숍 방문 목적 조사</legend></b></h1>

<fieldset>
  <legend>기본 정보</legend>

  <b>이름</b> <input type="text" id="name" required placeholder="햄깅이">
  <br><br>

  <b>연락처</b> <input type="text" id="phone" required placeholder="010-xxxx-xxxx">
  <br><br>

  <b>성별</b> 
  <input type="radio" name="gender" id="male"> <label for="male">남자</label>
  <input type="radio" name="gender" id="female"> <label for="female">여자</label>
  <br><br>

  <b>이메일</b> <input type="email" id="email" placeholder="hamgingee@hamging.ee">
  <br><br>

  <b>비밀번호</b> <input type="password" id="password">
</fieldset>

<fieldset>
  <legend>상세 정보</legend>
<b>가능 날짜</b> <input type="date" id="date" min="2026-03-23" max="2026-03-31" required>
<br>
<b>가능 시간</b> 
<select id="time" required>
  <option value="">시간 선택</option>
  <option value="10:00">오전 10:00</option>
  <option value="11:00">오전 11:00</option>
  <option value="12:00">오후 12:00</option>
  <option value="13:00">오후 01:00</option>
  <option value="14:00">오후 02:00</option>
  <option value="15:00">오후 03:00</option>
  <option value="16:00">오후 04:00</option>
  <option value="17:00">오후 05:00</option>
  <option value="18:00">오후 06:00</option>
  <option value="19:00">오후 07:00</option>
  <option value="20:00">오후 08:00</option>
</select>
<br>
<b>방문 목적</b> 
<select id="목적" multiple size="1" required>
<option value="">소장용</option>
<option value="">선물용</option>
<option value="">방문</option>
</select>
<br>

<b>방문 수단</b> 
<select id="수단" required>
<option value="">차량</option>
<option value="">대중교통</option>
<option value="">도보</option>
</select>
<br>
  </fieldset>

<fieldset>
<legend>좋아하는 캐릭터</legend>
<img src="/토낑이.png">
<input type="radio" name="character" value="tokking" id="char1">
    <label for="char1">토낑이</label>
<img src="/햄깅이.png">
<input type="radio" name="character" value="tokking" id="char1">
    <label for="char1">햄깅이</label>
<img src="/햄둥이.png">
<input type="radio" name="character" value="tokking" id="char1">
    <label for="char1">햄둥이</label>
</fieldset>
<input type="submit" value="완료">
<input type="reset" value="취소">
</body>
</html>
